# apex-pi — environment variables
# Copy this file to .env and adjust. The CLI and server both read from process.env.

# ───── HTTP server ────────────────────────────────────────────────────────
PORT=8080
HOST=0.0.0.0
LOG_LEVEL=info                    # debug | info | warn | error
WEB_UI=true                       # set false to disable the /  HTML UI

# ───── LLM provider (any OpenAI-compatible endpoint) ──────────────────────
# Defaults assume OpenAI. For OpenRouter / Anthropic / Ollama, just change
# LLM_BASE_URL.
LLM_PROVIDER=openai-compatible
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=sk-...                # also accepts OPENAI_API_KEY or ANTHROPIC_API_KEY
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.3
LLM_TIMEOUT_MS=60000
LLM_MAX_RETRIES=2

# ───── Storage ────────────────────────────────────────────────────────────
# APEX_PI_DATA holds the SQLite databases (apex-mem.sqlite, codegraph.sqlite).
# On Fly.io this is a persistent volume mounted at /data.
APEX_PI_DATA=./data

# ───── Memory (apex-mem) ──────────────────────────────────────────────────
APEXMEM_CAP=5000                  # max records per dimension
APEXMEM_DREAM_MIN=30              # dreaming sweep interval (minutes)
APEXMEM_DEDUP=0.92                # cosine-like dedup threshold

# To delegate memory to the Rust apex-mem binary (hernandez42/APEX-MEM),
# set this to its JSON-RPC / MCP URL. Otherwise the in-process engine is used.
# APEXMEM_URL=http://localhost:8765/mcp/rpc

# ───── Codegraph ──────────────────────────────────────────────────────────
CODEGRAPH_MAX_FILES=2000
CODEGRAPH_MAX_FILE_KB=256

# ───── Skills (ECC-style) ─────────────────────────────────────────────────
# Optional: directory of SKILL.md files to load on boot.
# SKILLS_DIR=./skills

# ───── Feishu / Lark channel ──────────────────────────────────────────────
FEISHU_ENABLED=false
FEISHU_APP_ID=cli_...
FEISHU_APP_SECRET=...
FEISHU_VERIFICATION_TOKEN=...
FEISHU_ENCRYPT_KEY=...
FEISHU_BOT_NAME=apex-pi

# ───── Durable workflows (Absurd / Postgres) ──────────────────────────────
# When ABSURD_DATABASE_URL is set, long-running operations like the
# /understand pipeline can be wrapped as durable workflows. Each phase
# becomes a checkpoint, so a process crash mid-run does not lose work —
# the worker resumes from the last completed phase on restart.
# Requires: absurdctl init + absurdctl create-queue <ABSURD_QUEUE>.
# See https://github.com/earendil-works/absurd for setup.
# ABSURD_ENABLED=1
# ABSURD_DATABASE_URL=postgres://user:pass@host:5432/apex_pi
# ABSURD_QUEUE=apex_pi_default
# ABSURD_CONCURRENCY=2                # max parallel task slots
# ABSURD_CLAIM_TIMEOUT=300            # seconds before a crashed task is re-claimed
